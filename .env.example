# ==================== BOT ====================
BOT_TOKEN=1234567890:AABBCCddEEFFggHHIIjjKKllMMnnOOpqrs

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Bot run mode: polling | webhook
BOT_RUN_MODE=polling

# ==================== WEBHOOK (optional) ====================
WEBHOOK_URL=https://your-domain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET_TOKEN=super-secret-token

# ==================== DATABASE ====================
# SQLite (default) - leave as is for local use
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vpnbot

# ==================== REMNAWAVE ====================
REMNAWAVE_API_URL=https://your-panel.remnawave.com
REMNAWAVE_API_KEY=your_remnawave_api_key

# ==================== PAYMENT - YOOKASSA ====================
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_EXTRA_PERCENT=5

# ==================== PAYMENT - CRYPTOBOT ====================
CRYPTOBOT_ENABLED=false
CRYPTOBOT_API_TOKEN=

# ==================== PAYMENT - TELEGRAM STARS ====================
TELEGRAM_STARS_ENABLED=false

# ==================== INTERNAL SQUADS ====================
# Get UUIDs from Remnawave panel → Internal Squads section
# Basic VPN users are added to BASIC_SQUAD_UUID
# Whitelist VPN users are added to BASIC_SQUAD_UUID + WHITELIST_SQUAD_UUID
BASIC_SQUAD_UUID=
WHITELIST_SQUAD_UUID=

# ==================== BOT SETTINGS ====================
# Bot name shown in messages
BOT_NAME=VPN Bot

# Channel username that users must subscribe to (leave empty to disable)
REQUIRED_CHANNEL=

# Trial period enabled
TRIAL_ENABLED=true
TRIAL_DAYS=3

# Currency
CURRENCY=RUB

# ==================== SUBSCRIPTION PLANS ====================
# Format: days:price_kopecks (price in kopecks = rubles*100)
PLAN_30_DAYS_PRICE=15000
PLAN_90_DAYS_PRICE=40000
PLAN_180_DAYS_PRICE=70000
PLAN_365_DAYS_PRICE=120000

# Premium plans (e.g. whitelist VPN)
PLAN_PREMIUM_30_DAYS_PRICE=25000
PLAN_PREMIUM_90_DAYS_PRICE=65000
PLAN_PREMIUM_180_DAYS_PRICE=110000
PLAN_PREMIUM_365_DAYS_PRICE=200000

# ==================== NOTIFICATIONS ====================
ADMIN_NOTIFICATIONS_ENABLED=true
ADMIN_NOTIFICATIONS_CHAT_ID=
ADMIN_NOTIFICATIONS_TOPIC_ID=
